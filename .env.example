# Copie para .env e ajuste se necessário:  cp .env.example .env

# URL da API usada pelo browser (build do front). Em deploy, troque pelo domínio público da API.
NEXT_PUBLIC_API_URL=http://localhost:8080/liv-api/

# Porta do Postgres exposta no host (evita conflito com outro Postgres local).
DB_EXTERNAL_PORT=5433

# AbacatePay (pagamento PIX). Vazio = modo mock/sandbox local.
# Para usar o sandbox real, informe uma chave dev (abc_dev_...).
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
